### ============================================================================
### VARIÁVEIS GLOBAIS
### ============================================================================
@baseUrl = http://localhost:8080

# Defina seus IDs de teste aqui
@categoryId = de2adf9b-eb08-40f8-aea2-9594569e228d
@taskId = c1ab8137-c359-492a-916e-06c76ec92fec
@taskToUpdateId = b43ec9e2-7f51-4bf6-b144-80b525244e80


### ============================================================================
### 🔐 AUTH (RODE ESTES PRIMEIRO)
### ============================================================================

# Registrar novo usuário
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "John Doe",
  "email": "johndoe@test.example",
  "password": "12345678",
  "role": "ADMIN"
}

###

# Fazer login e capturar o token
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "johndoe@test.example",
  "password": "12345678"
}

> {%
    if (response.status === 200) {
        var token = response.body.accessToken;
        client.global.set("auth_token", token);
        client.log("Token salvo: " + token);
    }
%}


### ============================================================================
### 🗂️ CATEGORIES
### ============================================================================

# Listar todas as categorias
GET {{baseUrl}}/categories
Authorization: Bearer {{auth_token}}

###

# Criar uma nova categoria
POST {{baseUrl}}/categories
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "name": "Estudos"
}


### ============================================================================
### ✅ TASKS
### ============================================================================

# Listar todas as tarefas
GET {{baseUrl}}/tasks
Authorization: Bearer {{auth_token}}

###

# Listar tarefas com filtro
GET {{baseUrl}}/tasks?status=DONE
Authorization: Bearer {{auth_token}}

###

# Criar uma nova tarefa
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "title": "Configurar banco de dados Produção",
  "description": "Criar a instância no AWS RDS e pegar as credenciais.",
  "priority": "HIGH",
  "dueTime": "2026-12-31T23:59:59.000Z",
  "categoryId": "{{categoryId}}"
}

###

# Atualizar uma tarefa existente
PATCH {{baseUrl}}/tasks/{{taskToUpdateId}}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "title": "Estudar Spring Data JPA",
  "description": "Fazer os relacionamentos funcionarem",
  "priority": "MEDIUM",
  "categoryId": "{{categoryId}}"
}

###

# Marcar tarefa como concluída
PATCH {{baseUrl}}/tasks/{{taskId}}/complete
Content-Type: application/json
Authorization: Bearer {{auth_token}}

###

# Deletar uma tarefa
DELETE {{baseUrl}}/tasks/{{taskId}}
Authorization: Bearer {{auth_token}}